# Default: normalize text files to LF in repository
* text=auto eol=lf

# Keep Windows script line endings for better compatibility on Windows runners
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.pdf binary
*.zip binary
*.7z binary
*.gz binary
*.ico binary
